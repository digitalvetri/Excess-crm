    "@excess/shared": "workspace:*",
    "bullmq": "^5.16.0",
    "ioredis": "^5.4.2",
    "axios": "^1.7.9",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.7",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
