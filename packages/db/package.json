{
  "name": "@excess/db",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:migrate:prod": "prisma migrate deploy",
    "db:migrate:check": "prisma migrate diff --from-migrations prisma/migrations --to-schema-datamodel prisma/schema.prisma --shadow-database-url \"$SHADOW_DATABASE_URL\" --exit-code",
    "db:studio": "prisma studio",
    "seed": "tsx src/seed.ts",
    "setup:rules": "tsx src/setup-pipeline-rules.ts",
    "seed:voice-prompts": "tsx src/seed-voice-prompts.ts",
    "probe:ddl": "tsx src/ddl-probe.ts",
    "seed:leads": "tsx src/seed-leads.ts",
    "seed:appointments": "tsx src/seed-appointments.ts",
    "seed:projects": "tsx src/seed-projects.ts",
    "seed:dashboard": "tsx src/seed-dashboard.ts",
    "seed:demo": "tsx src/seed.ts && tsx src/seed-leads.ts && tsx src/seed-appointments.ts && tsx src/seed-projects.ts && tsx src/seed-dashboard.ts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@prisma/client": "^5.14.0",
    "@excess/voice-agent": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "argon2": "^0.40.3",
    "prisma": "^5.14.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  }
}
