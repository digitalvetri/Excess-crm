generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum TenantType {
  HQ
  FRANCHISE
}

enum TenantStatus {
  ONBOARDING
  ACTIVE
  PROBATION
  SUSPENDED
  TERMINATED
}

enum FranchiseTier {
  BRONZE
  SILVER
  GOLD
}

// Job function within a franchise — separate from UserRole (system permission level)
enum FranchiseAgentRole {
  OWNER
  SALES
  SURVEY
  FOLLOWUP
}

enum UserRole {
  ADMIN
  EMPLOYEE
  FRANCHISE_OWNER
  FRANCHISE_USER
  ENGINEER
}

enum LeadSourceType {
  META
  INDIAMART
  JUSTDIAL
  WEBSITE
  WHATSAPP
  MANUAL
  PHONE_INBOUND
}

enum LeadStage {
  NEW
  QUALIFIED
  FOLLOW_UP
  CONVERTED
  NOT_ANSWERED
  INVALID
  WRONG_ENQUIRY
}

enum ActivityType {
  CALL
  SMS
  WHATSAPP
  NOTE
  STAGE_CHANGE
  ASSIGNMENT
  QUOTATION_SENT
  APPOINTMENT_BOOKED
  APPOINTMENT_CONFIRMED
  APPOINTMENT_COMPLETED
  APPOINTMENT_NO_SHOW
  APPOINTMENT_CANCELLED
  APPOINTMENT_RESCHEDULED
  EMAIL
  DUPLICATE_SUBMISSION
}

enum VoicePersona {
  RESHMA_VERIFY
  KARTHIK_SALES
  RESHMA_FOLLOWUP
  HUMAN
}

enum CallDirection {
  OUTBOUND
  INBOUND
}

enum CallStatus {
  QUEUED
  RINGING
  IN_PROGRESS
  COMPLETED
  NO_ANSWER
  BUSY
  FAILED
  DND_BLOCKED
}

enum AppointmentStatus {
  SCHEDULED
  CONFIRMED
  COMPLETED
  NO_SHOW
  RESCHEDULED
  CANCELLED
}

enum SurveyType {
  ROOFTOP_RESIDENTIAL
  COMMERCIAL
  INDUSTRIAL
  OFFGRID
}

enum QuotationStatus {
  DRAFT
  SENT
  ACCEPTED
  REJECTED
}

enum QuotationBrandTier {
  ECONOMY
  MID
  PREMIUM
}

enum SlaAction {
  NOTIFY
  REASSIGN
}

enum CsvImportStatus {
  PENDING
  PROCESSING
  DONE
  FAILED
}

enum CommissionStatus {
  PENDING_APPROVAL
  APPROVED
  PAID
  ON_HOLD
  DISPUTED
}

enum TicketCategory {
  TECHNICAL
  OPERATIONAL
  COMMERCIAL
  PRODUCT
  TRAINING
}

enum TicketPriority {
  P1
  P2
  P3
  P4
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

// ─── Core Tenancy ─────────────────────────────────────────────────────────────

model Tenant {
  id              String         @id @default(uuid()) @db.Uuid
  name            String
  type            TenantType
  status          TenantStatus   @default(ONBOARDING)
  tier            FranchiseTier?
  territory       Json?
  commissionSlabs  Json?          @map("commission_slabs")
  agentSplitConfig Json?          @map("agent_split_config")
  contactName      String?        @map("contact_name")
  contactEmail    String?        @map("contact_email")
  contactPhone    String?        @map("contact_phone")
  gstNumber       String?        @map("gst_number")
  bankAccount     Json?          @map("bank_account")
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")
  deletedAt       DateTime?      @map("deleted_at")

  users          User[]
  teams          Team[]
  leads          Lead[]
  leadSources    LeadSource[]
  calls          Call[]
  appointments   Appointment[]
  quotations     Quotation[]
  commissions      Commission[]
  commissionSplits CommissionSplit[]
  franchiseInvites FranchiseInvite[]
  payouts          Payout[]
  tickets        Ticket[]
  routingRules   RoutingRule[]
  voiceConfigs   VoiceAgentConfig[]
  voiceSettings  VoiceAgentSettings?
  whatsappConfig WhatsappConfig?
  waSessions     WaSession[]
  referrals      Referral[]
  reviews        Review[]
  wallet         Wallet?
  coachCache     CoachCache?
  savedViews     SavedView[]
  stageGates     StageGate[]
  slaRules       SlaRule[]
  csvImports     CsvImport[]
  projects       Project[]
  broadcasts     Broadcast[]
  sequences      Sequence[]
  serviceTickets ServiceTicket[]
  amcContracts   AmcContract[]
  savedReports   SavedReport[]
  webhookEndpoints WebhookEndpoint[]
  notifications    Notification[]

  @@map("tenants")
}

model User {
  id              String    @id @default(uuid()) @db.Uuid
  tenantId        String    @db.Uuid @map("tenant_id")
  email           String    @unique
  phone           String?
  passwordHash    String    @map("password_hash")
  twoFactorSecret String?   @map("two_factor_secret")
  name            String
  role            UserRole
  agentRole       FranchiseAgentRole? @map("agent_role")
  teamId          String?   @db.Uuid @map("team_id")
  isActive        Boolean   @default(true) @map("is_active")
  lastLoginAt     DateTime? @map("last_login_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  tenant           Tenant              @relation(fields: [tenantId], references: [id])
  team             Team?               @relation(fields: [teamId], references: [id])
  sessions         Session[]
  savedViews       SavedView[]
  commissionSplits CommissionSplit[]
  notifications    Notification[]

  @@index([tenantId])
  @@index([email])
  @@map("users")
}

model Session {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid @map("user_id")
  tenantId  String   @db.Uuid @map("tenant_id")
  role      UserRole
  teamId    String?  @db.Uuid @map("team_id")
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
  @@map("sessions")
}

model Team {
  id           String   @id @default(uuid()) @db.Uuid
  tenantId     String   @db.Uuid @map("tenant_id")
  name         String
  scope        Json     @default("{}")
  leaderUserId String?  @db.Uuid @map("leader_user_id")
  createdAt    DateTime @default(now()) @map("created_at")

  tenant       Tenant        @relation(fields: [tenantId], references: [id])
  members      User[]
  leads        Lead[]
  routingRules RoutingRule[]

  @@index([tenantId])
  @@map("teams")
}

model RoutingRule {
  id           String   @id @default(uuid()) @db.Uuid
  tenantId     String   @db.Uuid @map("tenant_id")
  priority     Int
  condition    Json
  targetTeamId String   @db.Uuid @map("target_team_id")
  isActive        Boolean  @default(true) @map("is_active")
  roundRobinIndex Int      @default(0) @map("round_robin_index")
  createdAt       DateTime @default(now()) @map("created_at")

  tenant     Tenant @relation(fields: [tenantId], references: [id])
  targetTeam Team   @relation(fields: [targetTeamId], references: [id])

  @@index([tenantId, priority])
  @@map("routing_rules")
}

// ─── Leads ────────────────────────────────────────────────────────────────────

model LeadSource {
  id         String         @id @default(uuid()) @db.Uuid
  tenantId   String         @db.Uuid @map("tenant_id")
  type       LeadSourceType
  label      String
  config     Json           @default("{}")
  isActive   Boolean        @default(true) @map("is_active")
  lastSyncAt DateTime?      @map("last_sync_at")
  createdAt  DateTime       @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id])
  leads  Lead[]

  @@index([tenantId])
  @@map("lead_sources")
}

model Lead {
  id               String         @id @default(uuid()) @db.Uuid
  tenantId         String         @db.Uuid @map("tenant_id")
  externalId       String?        @map("external_id")
  sourceId         String?        @db.Uuid @map("source_id")
  sourceType       LeadSourceType @map("source_type")
  campaignName     String?        @map("campaign_name")
  adName           String?        @map("ad_name")
  name             String
  phone            String
  phoneRaw         String         @map("phone_raw")
  email            String?
  pincode          String?
  city             String?
  state            String?
  rawPayload       Json           @default("{}") @map("raw_payload")
  language         String?
  aiScore          Int?           @map("ai_score")
  stage            LeadStage      @default(NEW)
  stageChangedAt   DateTime       @default(now()) @map("stage_changed_at")
  ownerUserId      String?        @db.Uuid @map("owner_user_id")
  teamId           String?        @db.Uuid @map("team_id")
  factSheet        Json?          @map("fact_sheet")
  tags             String[]       @default([]) @map("tags")
  aiScoreBreakdown Json?          @map("ai_score_breakdown")
  scoredAt         DateTime?      @map("scored_at")
  isDuplicate      Boolean        @default(false) @map("is_duplicate")
  duplicateOfId    String?        @db.Uuid @map("duplicate_of_id")
  utmSource        String?        @map("utm_source")
  utmMedium        String?        @map("utm_medium")
  utmCampaign      String?        @map("utm_campaign")
  utmContent       String?        @map("utm_content")
  utmTerm          String?        @map("utm_term")
  receivedAt       DateTime       @default(now()) @map("received_at")
  firstContactedAt DateTime?      @map("first_contacted_at")
  commsOptedOutAt  DateTime?      @map("comms_opted_out_at")
  createdAt        DateTime       @default(now()) @map("created_at")
  updatedAt        DateTime       @updatedAt @map("updated_at")

  tenant         Tenant          @relation(fields: [tenantId], references: [id])
  source         LeadSource?     @relation(fields: [sourceId], references: [id])
  team           Team?           @relation(fields: [teamId], references: [id])
  activities     LeadActivity[]
  calls          Call[]
  appointments   Appointment[]
  quotations     Quotation[]
  referrals      Referral[]
  reviews        Review[]
  project        Project?
  serviceTickets ServiceTicket[]
  amcContracts   AmcContract[]

  @@index([tenantId, stage, receivedAt])
  @@index([tenantId, phone])
  @@index([phone])
  @@map("leads")
}

model SavedView {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @db.Uuid @map("tenant_id")
  userId    String   @db.Uuid @map("user_id")
  name      String
  isShared  Boolean  @default(false) @map("is_shared")
  filters   Json     @default("{}") @map("filters")
  icon      String?  @map("icon")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id])
  user   User   @relation(fields: [userId], references: [id])

  @@index([tenantId, userId])
  @@map("saved_views")
}

model LeadActivity {
  id          String       @id @default(uuid()) @db.Uuid
  tenantId    String       @db.Uuid @map("tenant_id")
  leadId      String       @db.Uuid @map("lead_id")
  type        ActivityType
  actorUserId String?      @db.Uuid @map("actor_user_id")
  actorIsAi   Boolean      @default(false) @map("actor_is_ai")
  payload     Json         @default("{}")
  createdAt   DateTime     @default(now()) @map("created_at")

  lead Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([leadId, createdAt])
  @@index([tenantId, createdAt])
  @@map("lead_activities")
}

// ─── Voice Agent ──────────────────────────────────────────────────────────────

model Call {
  id            String        @id @default(uuid()) @db.Uuid
  tenantId      String        @db.Uuid @map("tenant_id")
  leadId        String        @db.Uuid @map("lead_id")
  persona       VoicePersona
  direction     CallDirection
  vapiCallId    String?       @unique @map("vapi_call_id")
  exotelCallSid String?       @map("exotel_call_sid")
  fromNumber    String        @map("from_number")
  toNumber      String        @map("to_number")
  initiatedAt   DateTime      @map("initiated_at")
  connectedAt   DateTime?     @map("connected_at")
  endedAt       DateTime?     @map("ended_at")
  durationSec   Int?          @map("duration_sec")
  status        CallStatus    @default(QUEUED)
  endReason     String?       @map("end_reason")
  recordingUrl  String?       @map("recording_url")
  recordingS3Key String?      @map("recording_s3_key")
  transcript    Json?
  llmAnalysis   Json?         @map("llm_analysis")
  costInr       Decimal?      @db.Decimal(10, 4) @map("cost_inr")
  sentiment       String?     @map("sentiment")
  objectionTags   String[]    @default([]) @map("objection_tags")
  intelAnalyzedAt DateTime?   @map("intel_analyzed_at")
  abVariant       String?     @map("ab_variant")
  createdAt     DateTime      @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id])
  lead   Lead   @relation(fields: [leadId], references: [id])

  @@index([leadId])
  @@index([tenantId, initiatedAt])
  @@map("calls")
}

model VoiceAgentConfig {
  id              String    @id @default(uuid()) @db.Uuid
  tenantId        String    @db.Uuid @map("tenant_id")
  personaId       String    @map("persona_id")
  systemPrompt    String    @db.Text @map("system_prompt")
  version         Int       @default(1)
  isActive        Boolean   @default(false) @map("is_active")
  abTestPercent   Int?      @map("ab_test_percent")
  activatedAt     DateTime? @map("activated_at")
  createdByUserId String?   @db.Uuid @map("created_by_user_id")
  createdAt       DateTime  @default(now()) @map("created_at")
  voiceConfig     Json?     @map("voice_config")

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId, personaId, version])
  @@map("voice_agent_configs")
}

model WhatsappConfig {
  id                 String    @id @default(uuid()) @db.Uuid
  tenantId           String    @unique @db.Uuid @map("tenant_id")
  phoneNumberId      String    @map("phone_number_id")
  businessAccountId  String    @map("business_account_id")
  accessToken        String    @map("access_token")
  webhookVerifyToken String    @default(dbgenerated("gen_random_uuid()::text")) @map("webhook_verify_token")
  displayName        String?   @map("display_name")
  isConnected        Boolean   @default(false) @map("is_connected")
  connectedAt        DateTime? @map("connected_at")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@map("whatsapp_configs")
}

model VoiceAgentSettings {
  id                 String   @id @default(uuid()) @db.Uuid
  tenantId           String   @unique @db.Uuid @map("tenant_id")
  businessHoursStart String   @default("09:00") @map("business_hours_start")
  businessHoursEnd   String   @default("21:00") @map("business_hours_end")
  timezone           String   @default("Asia/Kolkata")
  dailyCallCap       Int      @default(2000) @map("daily_call_cap")
  dndPolicy          Json     @default("{}") @map("dnd_policy")
  retryConfig        Json     @default("{}") @map("retry_config")
  abTestConfig       Json     @default("{}") @map("ab_test_config")
  updatedAt          DateTime @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@map("voice_agent_settings")
}

model DndList {
  id      String   @id @default(uuid()) @db.Uuid
  phone   String   @unique
  reason  String?
  addedAt DateTime @default(now()) @map("added_at")

  @@index([phone])
  @@map("dnd_list")
}

// ─── Appointments ─────────────────────────────────────────────────────────────

model Appointment {
  id                 String            @id @default(uuid()) @db.Uuid
  tenantId           String            @db.Uuid @map("tenant_id")
  leadId             String            @db.Uuid @map("lead_id")
  scheduledAt        DateTime          @map("scheduled_at")
  durationMin        Int               @default(60) @map("duration_min")
  surveyType         SurveyType        @map("survey_type")
  siteAddress        String            @map("site_address")
  siteLat            Decimal?          @db.Decimal(10, 7) @map("site_lat")
  siteLng            Decimal?          @db.Decimal(10, 7) @map("site_lng")
  assignedEngineerId String?           @db.Uuid @map("assigned_engineer_id")
  status             AppointmentStatus @default(SCHEDULED)
  preChecklist       Json?             @map("pre_checklist")
  postNotes          String?           @map("post_notes")
  createdByCallId    String?           @db.Uuid @map("created_by_call_id")
  confirmedAt        DateTime?         @map("confirmed_at")
  completedAt        DateTime?         @map("completed_at")
  cancelReason       String?           @map("cancel_reason")
  noShowAt           DateTime?         @map("no_show_at")
  checklistSentAt    DateTime?         @map("checklist_sent_at")
  waConfirmMsgId     String?           @map("wa_confirm_msg_id")
  surveyPhotoKeys    String[]          @default([]) @map("survey_photo_keys")
  estimatedKw        Decimal?          @db.Decimal(6, 2) @map("estimated_kw")
  roofCondition      String?           @map("roof_condition")
  completionToken    String?           @unique @map("completion_token")
  createdAt          DateTime          @default(now()) @map("created_at")
  updatedAt          DateTime          @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id])
  lead   Lead   @relation(fields: [leadId], references: [id])

  @@index([tenantId, scheduledAt])
  @@index([assignedEngineerId, scheduledAt])
  @@index([completionToken])
  @@map("appointments")
}

// ─── Quotations ───────────────────────────────────────────────────────────────

model Quotation {
  id              String             @id @default(uuid()) @db.Uuid
  tenantId        String             @db.Uuid @map("tenant_id")
  leadId          String             @db.Uuid @map("lead_id")
  number          String             @unique
  systemKw        Decimal            @map("system_kw")
  brandTier       QuotationBrandTier @map("brand_tier")
  totalInr        Decimal            @map("total_inr")
  subsidyInr      Decimal            @map("subsidy_inr")
  netPayable      Decimal            @map("net_payable")
  emiMonthly      Decimal?           @map("emi_monthly")
  paybackYears    Decimal?           @map("payback_years")
  lineItems       Json               @default("[]") @map("line_items")
  pdfS3Key        String?            @map("pdf_s3_key")
  sentAt          DateTime?          @map("sent_at")
  sentVia         String?            @map("sent_via")
  status          QuotationStatus    @default(DRAFT)
  createdByUserId String             @db.Uuid @map("created_by_user_id")
  createdAt       DateTime           @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id])
  lead   Lead   @relation(fields: [leadId], references: [id])

  @@index([tenantId, status])
  @@index([leadId])
  @@map("quotations")
}

// ─── Franchise Financials ─────────────────────────────────────────────────────

model Commission {
  id               String           @id @default(uuid()) @db.Uuid
  tenantId         String           @db.Uuid @map("tenant_id")
  leadId           String           @db.Uuid @map("lead_id")
  dealValueInr     Decimal          @map("deal_value_inr")
  ratePercent      Decimal          @map("rate_percent")
  commissionInr    Decimal          @map("commission_inr")
  gstInr           Decimal?         @map("gst_inr")
  deductionsInr    Decimal?         @map("deductions_inr")
  netPayableInr    Decimal          @map("net_payable_inr")
  status           CommissionStatus @default(PENDING_APPROVAL)
  approvedByUserId String?          @db.Uuid @map("approved_by_user_id")
  paidAt           DateTime?        @map("paid_at")
  payoutId         String?          @db.Uuid @map("payout_id")
  createdAt        DateTime         @default(now()) @map("created_at")

  tenant       Tenant           @relation(fields: [tenantId], references: [id])
  payout       Payout?          @relation(fields: [payoutId], references: [id])
  agentSplits  CommissionSplit[]

  @@index([tenantId, status])
  @@map("commissions")
}

model Payout {
  id            String      @id @default(uuid()) @db.Uuid
  tenantId      String      @db.Uuid @map("tenant_id")
  amountInr     Decimal     @map("amount_inr")
  bankUtr       String?     @map("bank_utr")
  paidAt        DateTime    @map("paid_at")
  commissionIds String[]    @map("commission_ids")
  createdAt     DateTime    @default(now()) @map("created_at")

  tenant      Tenant       @relation(fields: [tenantId], references: [id])
  commissions Commission[]

  @@index([tenantId])
  @@map("payouts")
}

// ─── Commission Splits & Franchise Invites ────────────────────────────────────

model CommissionSplit {
  id           String             @id @default(uuid()) @db.Uuid
  commissionId String             @db.Uuid @map("commission_id")
  userId       String             @db.Uuid @map("user_id")
  tenantId     String             @db.Uuid @map("tenant_id")
  agentRole    FranchiseAgentRole @map("agent_role")
  splitPercent Decimal            @map("split_percent")
  amountInr    Decimal            @map("amount_inr")
  paidAt       DateTime?          @map("paid_at")
  createdAt    DateTime           @default(now()) @map("created_at")

  commission Commission @relation(fields: [commissionId], references: [id])
  user       User       @relation(fields: [userId], references: [id])
  tenant     Tenant     @relation(fields: [tenantId], references: [id])

  @@index([commissionId])
  @@index([userId])
  @@index([tenantId])
  @@map("commission_splits")
}

model FranchiseInvite {
  id         String             @id @default(uuid()) @db.Uuid
  tenantId   String             @db.Uuid @map("tenant_id")
  email      String
  name       String
  agentRole  FranchiseAgentRole @map("agent_role")
  token      String             @unique
  expiresAt  DateTime           @map("expires_at")
  acceptedAt DateTime?          @map("accepted_at")
  createdAt  DateTime           @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([token])
  @@map("franchise_invites")
}

// ─── Support ──────────────────────────────────────────────────────────────────

model Ticket {
  id                 String         @id @default(uuid()) @db.Uuid
  tenantId           String         @db.Uuid @map("tenant_id")
  raisedByUserId     String         @db.Uuid @map("raised_by_user_id")
  category           TicketCategory
  priority           TicketPriority
  subject            String
  description        String         @db.Text
  attachments        Json?          @default("[]")
  status             TicketStatus   @default(OPEN)
  assignedToUserId   String?        @db.Uuid @map("assigned_to_user_id")
  slaDueAt           DateTime       @map("sla_due_at")
  resolvedAt         DateTime?      @map("resolved_at")
  satisfactionRating Int?           @map("satisfaction_rating")
  createdAt          DateTime       @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId, status])
  @@index([slaDueAt])
  @@map("tickets")
}

model KbArticle {
  id          String    @id @default(uuid()) @db.Uuid
  slug        String    @unique
  title       String
  body        String    @db.Text
  category    String
  language    String    @default("en")
  publishedAt DateTime? @map("published_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  @@map("kb_articles")
}

// ─── WhatsApp Sessions ────────────────────────────────────────────────────────

model WaSession {
  id                  String   @id @default(uuid()) @db.Uuid
  tenantId            String   @db.Uuid @map("tenant_id")
  leadId              String   @db.Uuid @map("lead_id")
  phone               String
  sessionExpiresAt    DateTime @map("session_expires_at")
  lastMessageAt       DateTime @map("last_message_at")
  npsPendingProjectId String?  @db.Uuid @map("nps_pending_project_id")
  createdAt           DateTime @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, phone])
  @@map("wa_sessions")
}

// ─── Network Effects ──────────────────────────────────────────────────────────

enum ReferralStatus {
  PENDING
  CONVERTED
  REWARDED
}

enum WalletTxType {
  CREDIT
  DEBIT
}

model Referral {
  id              String         @id @default(uuid()) @db.Uuid
  tenantId        String         @db.Uuid @map("tenant_id")
  referrerId      String         @db.Uuid @map("referrer_id")
  referredLeadId  String         @db.Uuid @map("referred_lead_id")
  status          ReferralStatus @default(PENDING)
  rewardInr       Decimal?       @db.Decimal(12, 2) @map("reward_inr")
  rewardedAt      DateTime?      @map("rewarded_at")
  createdAt       DateTime       @default(now()) @map("created_at")

  tenant       Tenant @relation(fields: [tenantId], references: [id])
  referredLead Lead   @relation(fields: [referredLeadId], references: [id])

  @@index([tenantId, status])
  @@index([referrerId])
  @@map("referrals")
}

model Review {
  id             String    @id @default(uuid()) @db.Uuid
  tenantId       String    @db.Uuid @map("tenant_id")
  leadId         String    @db.Uuid @map("lead_id")
  rating         Int?
  comment        String?   @db.Text
  source         String    @default("INTERNAL")
  npsScore       Int?      @map("nps_score")
  npsComment     String?   @db.Text @map("nps_comment")
  npsRequestedAt DateTime? @map("nps_requested_at")
  npsRespondedAt DateTime? @map("nps_responded_at")
  createdAt      DateTime  @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id])
  lead   Lead   @relation(fields: [leadId], references: [id])

  @@index([tenantId, createdAt])
  @@index([leadId])
  @@map("reviews")
}

model Wallet {
  id         String   @id @default(uuid()) @db.Uuid
  tenantId   String   @unique @db.Uuid @map("tenant_id")
  balanceInr Decimal  @default(0) @db.Decimal(14, 2) @map("balance_inr")
  updatedAt  DateTime @updatedAt @map("updated_at")

  tenant       Tenant              @relation(fields: [tenantId], references: [id])
  transactions WalletTransaction[]

  @@map("wallets")
}

model WalletTransaction {
  id          String       @id @default(uuid()) @db.Uuid
  walletId    String       @db.Uuid @map("wallet_id")
  tenantId    String       @db.Uuid @map("tenant_id")
  type        WalletTxType
  amountInr   Decimal      @db.Decimal(12, 2) @map("amount_inr")
  description String
  referenceId String?      @map("reference_id")
  createdAt   DateTime     @default(now()) @map("created_at")

  wallet Wallet @relation(fields: [walletId], references: [id])

  @@index([walletId, createdAt])
  @@index([tenantId, createdAt])
  @@map("wallet_transactions")
}

// ─── Audit Log ────────────────────────────────────────────────────────────────

model AuditLog {
  id          BigInt   @id @default(autoincrement())
  tenantId    String?  @db.Uuid @map("tenant_id")
  actorUserId String?  @db.Uuid @map("actor_user_id")
  action      String
  entityType  String   @map("entity_type")
  entityId    String   @db.Uuid @map("entity_id")
  diff        Json     @default("{}")
  ipAddress   String?  @map("ip_address")
  userAgent   String?  @map("user_agent")
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([tenantId, createdAt])
  @@index([entityType, entityId])
  @@map("audit_log")
}

// ─── Coach Cache ──────────────────────────────────────────────────────────────

model CoachCache {
  id         String   @id @default(uuid()) @db.Uuid
  tenantId   String   @unique @db.Uuid @map("tenant_id")
  tips       Json     @default("[]")
  computedAt DateTime @map("computed_at")

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@map("coach_cache")
}

// ─── Phase B: Process Intelligence ───────────────────────────────────────────

model StageGate {
  id                    String    @id @default(uuid()) @db.Uuid
  tenantId              String    @db.Uuid @map("tenant_id")
  stage                 LeadStage
  requiredFields        Json      @default("[]") @map("required_fields")
  requiredActivityTypes String[]  @default([]) @map("required_activity_types")
  isActive              Boolean   @default(true) @map("is_active")
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, stage])
  @@index([tenantId])
  @@map("stage_gates")
}

model SlaRule {
  id             String    @id @default(uuid()) @db.Uuid
  tenantId       String    @db.Uuid @map("tenant_id")
  stage          LeadStage
  thresholdHours Int       @map("threshold_hours")
  action         SlaAction
  notifyUserId   String?   @db.Uuid @map("notify_user_id")
  isActive       Boolean   @default(true) @map("is_active")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId, stage])
  @@map("sla_rules")
}

model CsvImport {
  id            String          @id @default(uuid()) @db.Uuid
  tenantId      String          @db.Uuid @map("tenant_id")
  userId        String          @db.Uuid @map("user_id")
  filename      String
  s3Key         String          @map("s3_key")
  fieldMap      Json            @default("{}") @map("field_map")
  totalRows     Int             @default(0) @map("total_rows")
  processedRows Int             @default(0) @map("processed_rows")
  errorRows     Int             @default(0) @map("error_rows")
  errors        Json            @default("[]")
  status        CsvImportStatus @default(PENDING)
  createdAt     DateTime        @default(now()) @map("created_at")
  updatedAt     DateTime        @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId, createdAt])
  @@map("csv_imports")
}

// ─── Phase C: Customer Lifecycle & Communications ────────────────────────────

enum ProjectStage {
  SURVEY
  DESIGN
  MATERIAL_ORDERED
  INSTALLATION
  COMMISSIONING
  HANDED_OVER
}

enum SubsidyScheme {
  NONE
  PM_SURYA_GHAR
  STATE_TEDA
  STATE_OTHER
}

enum SubsidyStatus {
  NOT_APPLIED
  APPLIED
  DISCOM_INSPECTION_SCHEDULED
  DISCOM_APPROVED
  PORTAL_UPLOAD_DONE
  CREDITED
}

enum NetMeteringStatus {
  NOT_APPLIED
  SLD_SUBMITTED
  LOAD_SANCTION_APPLIED
  INSPECTION_DONE
  METER_CHANGED
  GRID_SYNCED
  ACTIVE
}

enum ProjectDocumentCategory {
  QUOTATION
  WORK_ORDER
  MEASUREMENT_SHEET
  DESIGN_LAYOUT
  PURCHASE_ORDER
  COMMISSIONING_CERT
  NET_METERING_APPROVAL
  SUBSIDY_APPROVAL
  WARRANTY_CARD
  HANDOVER_CERT
  OTHER
}

enum ProjectPaymentType {
  ADVANCE
  MATERIALS
  INSTALLATION
  COMPLETION
  SUBSIDY
  AMC
  OTHER
}

enum BroadcastStatus {
  DRAFT
  SCHEDULED
  SENDING
  SENT
  FAILED
}

enum BroadcastRecipientStatus {
  PENDING
  SENT
  FAILED
  OPTED_OUT
}

enum CommsChannel {
  EMAIL
  WHATSAPP
  SMS
}

enum SequenceTrigger {
  LEAD_STAGE
  PROJECT_STAGE
  MANUAL
}

enum EnrollmentStatus {
  ACTIVE
  COMPLETED
  OPTED_OUT
  CANCELLED
}

enum ServiceTicketType {
  COMPLAINT
  AMC_VISIT
  WARRANTY
  GENERAL
}

enum AmcStatus {
  ACTIVE
  RENEWED
  CANCELLED
}

model Project {
  id                  String       @id @default(uuid()) @db.Uuid
  tenantId            String       @db.Uuid @map("tenant_id")
  leadId              String       @unique @db.Uuid @map("lead_id")
  quotationId         String?      @db.Uuid @map("quotation_id")
  surveyAppointmentId String?      @db.Uuid @map("survey_appointment_id")
  number              String       @unique
  systemKw            Decimal      @default(0) @map("system_kw")
  totalValueInr       Decimal      @default(0) @map("total_value_inr")
  stage               ProjectStage @default(SURVEY)
  stageChangedAt      DateTime     @default(now()) @map("stage_changed_at")
  surveyDoneAt        DateTime?    @map("survey_done_at")
  designApprovedAt    DateTime?    @map("design_approved_at")
  materialOrderedAt   DateTime?    @map("material_ordered_at")
  installStartedAt    DateTime?    @map("install_started_at")
  commissionedAt      DateTime?    @map("commissioned_at")
  handedOverAt        DateTime?    @map("handed_over_at")
  assignedEngineerId      String?           @db.Uuid @map("assigned_engineer_id")
  photos                  Json              @default("[]")
  notes                   String?           @db.Text
  // SLA
  expectedCompletionAt    DateTime?         @map("expected_completion_at")
  // Stage checklists: { "SURVEY": { "measure_roof": true }, ... }
  stageChecklists         Json              @default("{}") @map("stage_checklists")
  generationLog           Json              @default("[]") @map("generation_log")
  // Subsidy
  subsidyScheme           SubsidyScheme     @default(NONE) @map("subsidy_scheme")
  subsidyStatus           SubsidyStatus?    @map("subsidy_status")
  subsidyAppRef           String?           @db.VarChar(100) @map("subsidy_app_ref")
  subsidyExpectedAmtInr   Decimal?          @db.Decimal(12,2) @map("subsidy_expected_amt_inr")
  subsidyAppliedAt        DateTime?         @map("subsidy_applied_at")
  subsidyInspectionAt     DateTime?         @map("subsidy_inspection_at")
  subsidyApprovedAt       DateTime?         @map("subsidy_approved_at")
  subsidyPortalUploadAt   DateTime?         @map("subsidy_portal_upload_at")
  subsidyCreditedAt       DateTime?         @map("subsidy_credited_at")
  subsidyCreditedAmtInr   Decimal?          @db.Decimal(12,2) @map("subsidy_credited_amt_inr")
  // Net metering / DISCOM
  netMeteringStatus       NetMeteringStatus? @map("net_metering_status")
  netMeteringAppRef       String?           @db.VarChar(100) @map("net_metering_app_ref")
  netMeteringMeterNumber  String?           @db.VarChar(50) @map("net_metering_meter_number")
  netMeteringInspectorName String?          @db.VarChar(100) @map("net_metering_inspector_name")
  netMeteringSldAt        DateTime?         @map("net_metering_sld_at")
  netMeteringLoadAt       DateTime?         @map("net_metering_load_at")
  netMeteringInspectionAt DateTime?         @map("net_metering_inspection_at")
  netMeteringMeterAt      DateTime?         @map("net_metering_meter_at")
  netMeteringGridSyncAt   DateTime?         @map("net_metering_grid_sync_at")
  netMeteringFirstExportAt DateTime?        @map("net_metering_first_export_at")
  // Warranty & AMC
  panelWarrantyYears      Int               @default(25) @map("panel_warranty_years")
  inverterWarrantyYears   Int               @default(5) @map("inverter_warranty_years")
  installWarrantyYears    Int               @default(1) @map("install_warranty_years")
  warrantyStartDate       DateTime?         @map("warranty_start_date")
  amcExpiresAt            DateTime?         @map("amc_expires_at")
  createdAt               DateTime          @default(now()) @map("created_at")
  updatedAt               DateTime          @updatedAt @map("updated_at")

  tenant         Tenant            @relation(fields: [tenantId], references: [id])
  lead           Lead              @relation(fields: [leadId], references: [id])
  serviceTickets ServiceTicket[]
  amcContracts   AmcContract[]
  documents      ProjectDocument[]
  payments       ProjectPayment[]

  @@index([tenantId, stage])
  @@map("projects")
}

model ProjectDocument {
  id                  String                  @id @default(uuid()) @db.Uuid
  tenantId            String                  @db.Uuid @map("tenant_id")
  projectId           String                  @db.Uuid @map("project_id")
  category            ProjectDocumentCategory
  name                String                  @db.VarChar(200)
  s3Key               String                  @map("s3_key") @db.VarChar(500)
  sizeBytes           Int?                    @map("size_bytes")
  mimeType            String?                 @map("mime_type") @db.VarChar(100)
  uploadedByUserId    String                  @db.Uuid @map("uploaded_by_user_id")
  createdAt           DateTime                @default(now()) @map("created_at")

  project             Project                 @relation(fields: [projectId], references: [id])

  @@index([projectId])
  @@map("project_documents")
}

model ProjectPayment {
  id                  String             @id @default(uuid()) @db.Uuid
  tenantId            String             @db.Uuid @map("tenant_id")
  projectId           String             @db.Uuid @map("project_id")
  type                ProjectPaymentType
  amountInr           Decimal            @db.Decimal(12,2) @map("amount_inr")
  receivedAt          DateTime           @map("received_at")
  method              String?            @db.VarChar(30)
  reference           String?            @db.VarChar(100)
  notes               String?            @db.Text
  recordedByUserId    String             @db.Uuid @map("recorded_by_user_id")
  createdAt           DateTime           @default(now()) @map("created_at")

  project             Project            @relation(fields: [projectId], references: [id])

  @@index([projectId])
  @@map("project_payments")
}

model Broadcast {
  id              String          @id @default(uuid()) @db.Uuid
  tenantId        String          @db.Uuid @map("tenant_id")
  name            String
  channel         CommsChannel
  templateName    String?         @map("template_name")
  templateParams  Json            @default("{}") @map("template_params")
  bodyText        String?         @db.Text @map("body_text")
  audienceFilter  Json            @default("{}") @map("audience_filter")
  scheduledAt     DateTime?       @map("scheduled_at")
  startedAt       DateTime?       @map("started_at")
  completedAt     DateTime?       @map("completed_at")
  recipientCount  Int             @default(0) @map("recipient_count")
  sentCount       Int             @default(0) @map("sent_count")
  failedCount     Int             @default(0) @map("failed_count")
  status          BroadcastStatus @default(DRAFT)
  createdByUserId String          @db.Uuid @map("created_by_user_id")
  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @updatedAt @map("updated_at")

  tenant     Tenant               @relation(fields: [tenantId], references: [id])
  recipients BroadcastRecipient[]

  @@index([tenantId, status])
  @@map("broadcasts")
}

model BroadcastRecipient {
  id          String                   @id @default(uuid()) @db.Uuid
  broadcastId String                   @db.Uuid @map("broadcast_id")
  tenantId    String                   @db.Uuid @map("tenant_id")
  leadId      String                   @db.Uuid @map("lead_id")
  phone       String
  status      BroadcastRecipientStatus @default(PENDING)
  sentAt      DateTime?                @map("sent_at")
  error       String?
  createdAt   DateTime                 @default(now()) @map("created_at")

  broadcast Broadcast @relation(fields: [broadcastId], references: [id], onDelete: Cascade)

  @@index([broadcastId, status])
  @@map("broadcast_recipients")
}

model Sequence {
  id           String          @id @default(uuid()) @db.Uuid
  tenantId     String          @db.Uuid @map("tenant_id")
  name         String
  trigger      SequenceTrigger
  triggerValue String?         @map("trigger_value")
  isActive     Boolean         @default(true) @map("is_active")
  createdAt    DateTime        @default(now()) @map("created_at")
  updatedAt    DateTime        @updatedAt @map("updated_at")

  tenant      Tenant               @relation(fields: [tenantId], references: [id])
  steps       SequenceStep[]
  enrollments SequenceEnrollment[]

  @@index([tenantId, isActive])
  @@map("sequences")
}

model SequenceStep {
  id           String       @id @default(uuid()) @db.Uuid
  sequenceId   String       @db.Uuid @map("sequence_id")
  stepOrder    Int          @map("step_order")
  channel      CommsChannel
  templateName String       @map("template_name")
  params       Json         @default("{}")
  delayHours   Int          @default(0) @map("delay_hours")

  sequence Sequence @relation(fields: [sequenceId], references: [id], onDelete: Cascade)

  @@unique([sequenceId, stepOrder])
  @@map("sequence_steps")
}

model SequenceEnrollment {
  id          String           @id @default(uuid()) @db.Uuid
  tenantId    String           @db.Uuid @map("tenant_id")
  sequenceId  String           @db.Uuid @map("sequence_id")
  leadId      String           @db.Uuid @map("lead_id")
  currentStep Int              @default(0) @map("current_step")
  status      EnrollmentStatus @default(ACTIVE)
  nextRunAt   DateTime         @map("next_run_at")
  enrolledAt  DateTime         @default(now()) @map("enrolled_at")
  completedAt DateTime?        @map("completed_at")

  sequence Sequence @relation(fields: [sequenceId], references: [id], onDelete: Cascade)

  @@unique([sequenceId, leadId])
  @@index([status, nextRunAt])
  @@map("sequence_enrollments")
}

model ServiceTicket {
  id                 String            @id @default(uuid()) @db.Uuid
  tenantId           String            @db.Uuid @map("tenant_id")
  projectId          String?           @db.Uuid @map("project_id")
  leadId             String            @db.Uuid @map("lead_id")
  type               ServiceTicketType
  subject            String
  description        String            @db.Text
  status             TicketStatus      @default(OPEN)
  priority           TicketPriority    @default(P3)
  scheduledVisitAt   DateTime?         @map("scheduled_visit_at")
  assignedEngineerId String?           @db.Uuid @map("assigned_engineer_id")
  resolvedAt         DateTime?         @map("resolved_at")
  activityLog        Json              @default("[]") @map("activity_log")
  createdByUserId    String?           @db.Uuid @map("created_by_user_id")
  createdAt          DateTime          @default(now()) @map("created_at")
  updatedAt          DateTime          @updatedAt @map("updated_at")

  tenant  Tenant   @relation(fields: [tenantId], references: [id])
  project Project? @relation(fields: [projectId], references: [id])
  lead    Lead     @relation(fields: [leadId], references: [id])

  @@index([tenantId, status])
  @@index([projectId])
  @@index([scheduledVisitAt])
  @@map("service_tickets")
}

model AmcContract {
  id              String    @id @default(uuid()) @db.Uuid
  tenantId        String    @db.Uuid @map("tenant_id")
  projectId       String    @db.Uuid @map("project_id")
  leadId          String    @db.Uuid @map("lead_id")
  planYears       Int       @default(1) @map("plan_years")
  startDate       DateTime  @map("start_date")
  endDate         DateTime  @map("end_date")
  valueInr        Decimal?  @db.Decimal(12,2) @map("value_inr")
  status          AmcStatus @default(ACTIVE)
  notes           String?   @db.Text
  createdByUserId String?   @db.Uuid @map("created_by_user_id")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  tenant  Tenant  @relation(fields: [tenantId], references: [id])
  project Project @relation(fields: [projectId], references: [id])
  lead    Lead    @relation(fields: [leadId], references: [id])

  @@index([tenantId, status])
  @@index([tenantId, endDate])
  @@index([projectId])
  @@map("amc_contracts")
}

// ─── Phase D: Intelligence & Insights ────────────────────────────────────────

model SavedReport {
  id              String   @id @default(uuid()) @db.Uuid
  tenantId        String   @db.Uuid @map("tenant_id")
  name            String
  definition      Json     @default("{}")
  isShared        Boolean  @default(false) @map("is_shared")
  createdByUserId String   @db.Uuid @map("created_by_user_id")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@map("saved_reports")
}

// ─── Notifications ────────────────────────────────────────────────────────────

model Notification {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @db.Uuid @map("tenant_id")
  userId    String   @db.Uuid @map("user_id")
  type      String
  title     String
  body      String?
  linkHref  String?  @map("link_href")
  isRead    Boolean  @default(false) @map("is_read")
  createdAt DateTime @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id])
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tenantId, userId, isRead, createdAt(sort: Desc)])
  @@map("notifications")
}

// ─── Outbound Webhooks ────────────────────────────────────────────────────────

model WebhookEndpoint {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @db.Uuid @map("tenant_id")
  url         String
  secret      String
  description String?
  events      String[]
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  tenant    Tenant             @relation(fields: [tenantId], references: [id])
  deliveries WebhookDelivery[]

  @@index([tenantId, isActive])
  @@map("webhook_endpoints")
}

model WebhookDelivery {
  id          String   @id @default(uuid()) @db.Uuid
  endpointId  String   @db.Uuid @map("endpoint_id")
  event       String
  payload     Json
  statusCode  Int?     @map("status_code")
  responseMs  Int?     @map("response_ms")
  success     Boolean  @default(false)
  error       String?
  attemptedAt DateTime @default(now()) @map("attempted_at")

  endpoint WebhookEndpoint @relation(fields: [endpointId], references: [id], onDelete: Cascade)

  @@index([endpointId, attemptedAt])
  @@map("webhook_deliveries")
}
